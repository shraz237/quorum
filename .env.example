# =============================================================================
# Brent Crude Trading Bot — Environment Variables
# Copy this file to .env and fill in your keys before running.
# =============================================================================

# AI / LLM
ANTHROPIC_API_KEY=          # https://console.anthropic.com/
XAI_API_KEY=                # https://console.x.ai/

# Telegram notifications
TELEGRAM_BOT_TOKEN=         # https://t.me/BotFather
TELEGRAM_CHAT_ID=           # run @userinfobot in Telegram to find your chat ID

# Market data
ALPHA_VANTAGE_API_KEY=      # https://www.alphavantage.co/support/#api-key
EIA_API_KEY=                # https://www.eia.gov/opendata/register.php
QUANDL_API_KEY=             # https://data.nasdaq.com/sign-up
FRED_API_KEY=               # https://fred.stlouisfed.org/docs/api/api_key.html

# Infrastructure (defaults work with docker-compose)
POSTGRES_URL=postgresql://trading:trading@postgres:5432/trading
REDIS_URL=redis://redis:6379

# Optional — Shipping / vessel tracking
DATALASTIC_API_KEY=         # https://datalastic.com/
VESSEL_FINDER_API_KEY=      # https://www.vesselfinder.com/developers
SIGNAL_OCEAN_API_KEY=       # https://www.signalocean.com/
